# Copie ce fichier en ".env" et renseigne tes clés.
# docker compose lit automatiquement le fichier .env du même dossier.

# --- Ringover (téléphonie) -------------------------------------------------
# Dashboard Ringover > Developer > API key > Create an API key
RINGOVER_API_KEY=
# Numéro du commercial pour le click-to-call (format international, ex +32475123456)
RINGOVER_DEFAULT_NUMBER=

# --- Enrichissement financier (optionnel) ----------------------------------
# Clé API gratuite BNB : inscription sur https://developer.cbso.nbb.be
# Produit recommandé : "Improved prod access" (non-perf, gratuit)
NBB_API_KEY=
# CompanyWeb : nécessite un abonnement payant
COMPANYWEB_API_KEY=

# --- Briefing IA pré-appel (optionnel) -------------------------------------
# Au moins l'une des deux clés ci-dessous pour activer le briefing IA.
# OpenAI prioritaire si les deux sont définies (gpt-4o-mini, ~0.0003 €/briefing)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic fallback (claude-haiku-4-5, ~0.001 €/briefing)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Alternative qualité : claude-sonnet-4-5-20250929

# Pour forcer un provider (sinon : OpenAI prioritaire)
# AI_BRIEFING_PROVIDER=anthropic
